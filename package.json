{
  "name": "educore-backend",
  "version": "1.0.0",
  "description": "Real-time SQL Backend for School Management System",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "validate": "node scripts/validate-startup.js",
    "validate:start": "npm run validate && npm start",
    "production": "NODE_ENV=production node app.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs school-crm",
    "pm2:save": "pm2 save",
    "pm2:delete": "pm2 delete ecosystem.config.js"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.21.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "nodemon": "^3.1.14",
    "qrcode": "^1.5.4",
    "sequelize": "^6.33.0",
    "socket.io": "^4.7.2"
  }
}
