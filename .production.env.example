# ============================================
# Production Environment Configuration
# For cPanel Hosting
# ============================================
# Copy this file to .env and fill in your values

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_cpanel_database_name
DB_USER=your_cpanel_db_user
DB_PASSWORD=your_cpanel_db_password

# Application Settings
PORT=3000
NODE_ENV=production
ENVIRONMENT=production

# JWT & Security
JWT_SECRET=change_this_to_a_very_strong_secret_key_min_32_chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password

# SMTP Email Configuration (Gmail or custom SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=Your School Name

# Email Reminder Settings
PENDING_FEE_REMINDER_ENABLED=true
PENDING_FEE_REMINDER_TIME=09:00
PENDING_FEE_REMINDER_TIMEZONE=Asia/Karachi
PENDING_FEE_REMINDER_RUN_ON_START=true

# Principal Account (Default Login)
PRINCIPAL_USERNAME=principal@school.com
PRINCIPAL_PASSWORD=change_this_strong_password

# Database Auto-Creation (set to false for shared hosting)
AUTO_CREATE_DB=false

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Security
TRUST_PROXY=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WhatsApp Integration (Optional)
WHATSAPP_ENABLED=false
WHATSAPP_API_KEY=your_whatsapp_api_key

# Session Management
SESSION_MAX_AGE=3600000
SESSION_STORE_TYPE=memory
