# Hostinger Production .env Template
# Replace values with your actual Hostinger credentials

# DATABASE CONFIGURATION
DB_HOST=localhost
DB_NAME=school_system
DB_USER=school_user
DB_PASSWORD=YOUR_MYSQL_PASSWORD_HERE
DB_PORT=3306

# APPLICATION
PORT=3000
NODE_ENV=production
APP_URL=https://apexiumsschool.com

# JWT & SECURITY
JWT_SECRET=your_very_secure_secret_key_change_this_to_something_unique_2026
JWT_EXPIRE=30d

# ADMIN CREDENTIALS
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# EMAIL CONFIGURATION (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=pessabubakar65@gmail.com
SMTP_PASS=melqyptsoeabtnlk
SMTP_FROM_EMAIL=pessabubakar65@gmail.com
SMTP_FROM_NAME=PESS JAND

# FEE REMINDERS
PENDING_FEE_REMINDER_ENABLED=true
PENDING_FEE_REMINDER_TIME=09:00
PENDING_FEE_REMINDER_TIMEZONE=Asia/Karachi
PENDING_FEE_REMINDER_RUN_ON_START=true

# PRINCIPAL CREDENTIALS
PRINCIPAL_USERNAME=principal@school.com
PRINCIPAL_PASSWORD=Principal123

# LOGGING
LOG_LEVEL=info
LOG_FILE=/home/username/logs/school-crm.log

# SECURITY
CORS_ORIGIN=https://apexiumsschool.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=15

# OPTIONAL: Redis (for caching)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
